# --- 農會後台管理系統環境變數範本 (.env.example) ---
# 使用方式：請複製此檔案並重新命名為 .env，然後根據需求修改內容

# 1. API 基礎路徑
# 開發時通常指向 localhost，正式串接時指向後端伺服器位址
VITE_API_BASE_URL=http://localhost:3000/api

# 2. 應用程式標題
VITE_APP_TITLE=Farmer Admin System

# 3. Mock 資料開關
# true: 使用前端 Mock 資料 (開發初期使用)
# false: 串接真實後端 API
VITE_USE_MOCK=true

# 4. 其他配置 (視未來需求增加)
# VITE_SENTRY_DSN= (錯誤監控)
# VITE_GOOGLE_MAPS_KEY= (地圖金鑰)
